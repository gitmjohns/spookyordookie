# Copy this file to .env.local and fill in real values.
# Never commit .env.local or any file containing real credentials.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── TMDB ──────────────────────────────────────────────────────────────────────
# Found in: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key

# ── Cron / API route protection ───────────────────────────────────────────────
# Generate with: openssl rand -base64 32
CRON_SECRET=your_random_secret_string

# ── Resend ────────────────────────────────────────────────────────────────────
# Found in: https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key

# ── OAuth ─────────────────────────────────────────────────────────────────────
# Google and Discord OAuth credentials are configured in the Supabase dashboard
# under Authentication → Providers. No secrets are needed here in the app.
